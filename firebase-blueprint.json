{
  "entities": {
    "UserPrivate": {
      "title": "User Private Data",
      "description": "Sensitive information for a user",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "UserPublic": {
      "title": "User Public Profile",
      "description": "Publicly visible user information",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "xp": { "type": "number" },
        "level": { "type": "number" },
        "badges": { "type": "number" },
        "completedLessons": { "type": "array", "items": { "type": "string" } },
        "completedChallenges": { "type": "array", "items": { "type": "string" } },
        "library": { "type": "array", "items": { "type": "string" }, "description": "Bookmarked tutorial IDs" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["displayName", "xp", "level", "badges"]
    },
    "GlobalStats": {
      "title": "Global Platform Stats",
      "description": "Aggregated stats for the platform",
      "type": "object",
      "properties": {
        "totalUsers": { "type": "number" },
        "totalXP": { "type": "number" }
      },
      "required": ["totalUsers", "totalXP"]
    },
    "Lesson": {
      "title": "Lesson",
      "description": "A tutorial lesson in the platform",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "content": { "type": "string" },
        "codeExample": { "type": "string" },
        "quiz": {
          "type": "object",
          "properties": {
            "question": { "type": "string" },
            "options": { "type": "array", "items": { "type": "string" } },
            "correctAnswer": { "type": "number" }
          }
        }
      },
      "required": ["id", "title", "description", "content", "codeExample", "quiz"]
    },
    "DailyQuestPDF": {
      "title": "Daily Quest PDF",
      "description": "Metadata for an uploaded PDF",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "uploadedAt": { "type": "string", "format": "date-time" },
        "url": { "type": "string" }
      },
      "required": ["name", "uploadedAt"]
    },
    "QuestCategory": {
      "title": "Quest Category",
      "description": "A category of daily quests (e.g., First Test)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "isLocked": { "type": "boolean" },
        "order": { "type": "number" }
      },
      "required": ["id", "name", "isLocked", "order"]
    },
    "QuestQuestion": {
      "title": "Quest Question",
      "description": "An MCQ question for a specific category",
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "correctAnswer": { "type": "number" },
        "codeSnippet": { "type": "string" },
        "categoryId": { "type": "string" }
      },
      "required": ["question", "options", "correctAnswer", "categoryId"]
    },
    "QuestAttempt": {
      "title": "Quest Attempt",
      "description": "A student's attempt at a specific quest category",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "score": { "type": "number" },
        "total": { "type": "number" },
        "categoryId": { "type": "string" },
        "testName": { "type": "string" },
        "attemptedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "score", "total", "categoryId", "testName", "attemptedAt"]
    }
  },
  "firestore": {
    "/quest_categories/{categoryId}": {
      "schema": "QuestCategory",
      "description": "Categories for daily quests"
    },
    "/users_private/{userId}": {
      "schema": "UserPrivate",
      "description": "Private user data"
    },
    "/users_public/{userId}": {
      "schema": "UserPublic",
      "description": "Public user profiles"
    },
    "/global_stats/platform": {
      "schema": "GlobalStats",
      "description": "Platform-wide statistics"
    },
    "/lessons/{lessonId}": {
      "schema": "Lesson",
      "description": "Tutorial lessons"
    },
    "/daily_quest_pdfs/{pdfId}": {
      "schema": "DailyQuestPDF",
      "description": "Uploaded PDF metadata for quests"
    },
    "/quest_questions/{questionId}": {
      "schema": "QuestQuestion",
      "description": "MCQ questions for daily quests"
    },
    "/quest_attempts/{attemptId}": {
      "schema": "QuestAttempt",
      "description": "Student attempts and scores for daily quests"
    }
  }
}
